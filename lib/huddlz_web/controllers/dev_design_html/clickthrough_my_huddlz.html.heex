<.clickthrough_shell active={@active} query={@query} signed_in={@signed_in}>
  <div class="page-head">
    <div>
      <h1>My huddlz</h1>
      <p>Everything you've RSVP'd to, are hosting, or are watching from the waitlist.</p>
    </div>
  </div>

  <div class="filters">
    <button class="chip is-active">Upcoming · 6</button>
    <button class="chip">Waitlisted · 1</button>
    <button class="chip">Hosting · 2</button>
    <button class="chip">Past</button>
  </div>

  <div class="grid">
    <a class="card" href="/dev/design/clickthrough/huddl">
      <div class="card-cover gradient-1">
        <img class="card-cover-img" src="/dev/design/images/product-night.svg" alt="" />
        <div class="date-stamp"><span class="m">MAY</span><span class="d">22</span></div>
        <span class="card-tag hybrid">Hybrid</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix Elixir · Workshop</span>
        <div class="card-title">Ash Framework workshop</div>
        <div class="card-meta">
          <span>Thu · 6:00 PM</span><span class="dot"></span><span>28 / 40 RSVPs</span>
        </div>
      </div>
      <div class="card-foot">
        <span class="pill cyan">Hosting</span>
        <span class="muted" style="font-size:12px">3 days away</span>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/huddl">
      <div class="card-cover gradient-4">
        <img class="card-cover-img" src="/dev/design/images/ai-meetup.svg" alt="" />
        <div class="date-stamp"><span class="m">MAY</span><span class="d">28</span></div>
        <span class="card-tag hybrid">Hybrid</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix Elixir · Talk</span>
        <div class="card-title">LiveView deep dive · streams &amp; async</div>
        <div class="card-meta">
          <span>Wed · 6:30 PM</span><span class="dot"></span><span>34 / 60 RSVPs</span>
        </div>
      </div>
      <div class="card-foot">
        <span class="pill">Going</span>
        <span class="muted" style="font-size:12px">9 days away</span>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/huddl">
      <div class="card-cover gradient-2">
        <img class="card-cover-img" src="/dev/design/images/boat-drinks.svg" alt="" />
        <div class="date-stamp"><span class="m">JUN</span><span class="d">04</span></div>
        <span class="card-tag in-person">In person</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix Elixir · Social</span>
        <div class="card-title">Phoenix Elixir social</div>
        <div class="card-meta">
          <span>Tue · 7:00 PM</span><span class="dot"></span><span>18 RSVPs</span>
        </div>
      </div>
      <div class="card-foot">
        <span class="pill cyan">Hosting</span>
        <span class="muted" style="font-size:12px">2 weeks away</span>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/huddl">
      <div class="card-cover gradient-5">
        <img class="card-cover-img" src="/dev/design/images/boat-drinks.svg" alt="" />
        <div class="date-stamp"><span class="m">JUN</span><span class="d">07</span></div>
        <span class="card-tag in-person">In person</span>
      </div>
      <div class="card-body">
        <span class="card-group">Sonoran AI Collective · Social</span>
        <div class="card-title">AI builders happy hour</div>
        <div class="card-meta">
          <span>Sat · 6:00 PM</span><span class="dot"></span><span>52 / 60 RSVPs</span>
        </div>
      </div>
      <div class="card-foot">
        <span class="pill warn">Waitlist · #3</span>
        <span class="muted" style="font-size:12px">3 weeks away</span>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/huddl">
      <div class="card-cover gradient-3">
        <img class="card-cover-img" src="/dev/design/images/founder-coffee.svg" alt="" />
        <div class="date-stamp"><span class="m">JUN</span><span class="d">11</span></div>
        <span class="card-tag hybrid">Hybrid</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix Elixir · Workshop</span>
        <div class="card-title">Property-based testing intro</div>
        <div class="card-meta">
          <span>Wed · 6:30 PM</span><span class="dot"></span><span>12 RSVPs</span>
        </div>
      </div>
      <div class="card-foot">
        <span class="pill">Going</span>
        <span class="muted" style="font-size:12px">3 weeks away</span>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/huddl">
      <div class="card-cover gradient-6">
        <img class="card-cover-img" src="/dev/design/images/ai-meetup.svg" alt="" />
        <div class="date-stamp"><span class="m">JUN</span><span class="d">18</span></div>
        <span class="card-tag in-person">In person</span>
      </div>
      <div class="card-body">
        <span class="card-group">Sonoran AI Collective · Talk</span>
        <div class="card-title">Agents in production: lessons learned</div>
        <div class="card-meta">
          <span>Tue · 6:00 PM</span><span class="dot"></span><span>78 RSVPs</span>
        </div>
      </div>
      <div class="card-foot">
        <span class="pill">Going</span>
        <span class="muted" style="font-size:12px">5 weeks away</span>
      </div>
    </a>
  </div>
</.clickthrough_shell>
