<.clickthrough_shell active={@active} query={@query} signed_in={@signed_in}>
  <div class="page-head">
    <div>
      <h1>Notifications</h1>
      <p>RSVPs, group activity, reminders, and invites that need your response.</p>
    </div>
    <div class="actions">
      <button class="btn-secondary">Mark all as read</button>
    </div>
  </div>

  <div class="filters">
    <button class="chip is-active">Inbox · 12 unread</button>
    <button class="chip">Invites · 2</button>
  </div>

  <div class="panel" style="padding:0">
    <div class="row-list" style="padding:0 20px">
      <div class="row notif-row unread">
        <div class="notif-mark cyan" aria-hidden="true"></div>
        <div>
          <div class="row-title">7 new RSVPs to Ash Framework workshop</div>
          <div class="meta">Phoenix Elixir · 2 hours ago</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
      <div class="row notif-row unread">
        <div class="notif-mark cyan" aria-hidden="true"></div>
        <div>
          <div class="row-title">Reminder: AI builders happy hour starts in 24 hours</div>
          <div class="meta">Sonoran AI Collective · 4 hours ago</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
      <div class="row notif-row unread">
        <div class="notif-mark warn" aria-hidden="true"></div>
        <div>
          <div class="row-title">You were promoted from waitlist · Saturday 5K + coffee</div>
          <div class="meta">Trail Coffee Crew · this morning</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
      <div class="row notif-row unread">
        <div class="notif-mark cyan" aria-hidden="true"></div>
        <div>
          <div class="row-title">Alice Johnson published a new huddl in Phoenix Elixir</div>
          <div class="meta">"LiveView deep dive" · yesterday</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
      <div class="row notif-row unread">
        <div class="notif-mark cyan" aria-hidden="true"></div>
        <div>
          <div class="row-title">Sara Kim joined Phoenix Elixir</div>
          <div class="meta">2 days ago</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/group">Open</a>
      </div>
      <div class="row notif-row">
        <div class="notif-mark muted" aria-hidden="true"></div>
        <div>
          <div class="row-title">RSVP confirmed · Property-based testing intro</div>
          <div class="meta">Phoenix Elixir · 3 days ago</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
      <div class="row notif-row">
        <div class="notif-mark muted" aria-hidden="true"></div>
        <div>
          <div class="row-title">Diego Lopez RSVP'd to Phoenix Elixir social</div>
          <div class="meta">Phoenix Elixir · 4 days ago</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
      <div class="row notif-row">
        <div class="notif-mark muted" aria-hidden="true"></div>
        <div>
          <div class="row-title">Phoenix 1.8 walkthrough was updated</div>
          <div class="meta">Time changed · 1 week ago</div>
        </div>
        <a class="pill" href="/dev/design/clickthrough/huddl">Open</a>
      </div>
    </div>
  </div>
</.clickthrough_shell>
