<.clickthrough_shell active={@active} query={@query} signed_in={@signed_in}>
  <div class="page-head">
    <div>
      <h1>Overview</h1>
      <p>
        What's happening in your group right now. Two huddlz need attention this week — one's filling fast, one needs a venue.
      </p>
    </div>
    <div class="actions">
      <button class="btn-secondary">Invite</button>
      <a class="btn-primary" href="/dev/design/clickthrough/huddl-new">+ Schedule huddl</a>
    </div>
  </div>

  <div class="kpis">
    <div class="kpi">
      <div class="label">Members</div>
      <div class="value">642</div>
      <div class="delta">+18 this month</div>
      <svg class="spark" viewBox="0 0 100 28" preserveAspectRatio="none">
        <polyline
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          points="0,22 12,20 24,18 36,17 48,15 60,13 72,12 84,10 96,8"
        />
      </svg>
    </div>
    <div class="kpi">
      <div class="label">Avg RSVPs / huddl</div>
      <div class="value">31</div>
      <div class="delta">+12% vs last 90d</div>
      <svg class="spark" viewBox="0 0 100 28" preserveAspectRatio="none">
        <polyline
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          points="0,18 12,20 24,16 36,18 48,12 60,15 72,11 84,8 96,10"
        />
      </svg>
    </div>
    <div class="kpi">
      <div class="label">Show-up rate</div>
      <div class="value">78%</div>
      <div class="delta warn">−4 pts vs last quarter</div>
      <svg class="spark" viewBox="0 0 100 28" preserveAspectRatio="none">
        <polyline
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          points="0,8 12,10 24,9 36,11 48,13 60,12 72,14 84,16 96,15"
          stroke="currentColor"
        />
      </svg>
    </div>
    <div class="kpi">
      <div class="label">Upcoming</div>
      <div class="value">5</div>
      <div class="delta muted">Next 30 days · 2 hybrid, 3 in-person</div>
    </div>
  </div>

  <div class="panel split">
    <div>
      <div class="panel-head">
        <h2>Needs your attention</h2>
        <span class="muted" style="font-size:12px">2 items</span>
      </div>
      <div class="row-list">
        <div class="row" style="grid-template-columns:1fr auto">
          <div>
            <div class="row-title">Ash Framework workshop · May 22</div>
            <div class="meta">28 / 40 RSVPs · 3 waitlisted · likely sells out</div>
          </div>
          <a class="pill warn" href="/dev/design/clickthrough/huddl">Raise capacity</a>
        </div>
        <div class="row" style="grid-template-columns:1fr auto">
          <div>
            <div class="row-title">Phoenix Elixir social · Jun 4</div>
            <div class="meta">No venue confirmed · 12 days out</div>
          </div>
          <a class="pill warn" href="#">Set venue</a>
        </div>
        <div class="row" style="grid-template-columns:1fr auto">
          <div>
            <div class="row-title">12 new members joined this week</div>
            <div class="meta">See who's new in Members</div>
          </div>
          <a class="pill" href="/dev/design/clickthrough/organize-members">Members</a>
        </div>
      </div>
    </div>

    <div>
      <div class="panel-head">
        <h2>Recent activity</h2>
      </div>
      <div class="row-list">
        <div class="row" style="grid-template-columns:1fr">
          <div>
            <div class="row-title">Alice Johnson published a huddl</div>
            <div class="meta">"LiveView deep dive" · 2 hours ago</div>
          </div>
        </div>
        <div class="row" style="grid-template-columns:1fr">
          <div>
            <div class="row-title">7 new RSVPs</div>
            <div class="meta">Ash Framework workshop · today</div>
          </div>
        </div>
        <div class="row" style="grid-template-columns:1fr">
          <div>
            <div class="row-title">Templates · 2 unused for 60+ days</div>
            <div class="meta">Consider archiving</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="panel">
    <div class="panel-head">
      <div>
        <h2>Upcoming huddlz</h2>
        <div class="panel-sub">Next 30 days · scoped to this group</div>
      </div>
      <a class="pill" href="/dev/design/clickthrough/organize-huddlz">View all</a>
    </div>
    <div class="grid two">
      <a class="card" href="/dev/design/clickthrough/huddl">
        <div class="card-cover gradient-1">
          <img class="card-cover-img" src="/dev/design/images/product-night.svg" alt="" />
          <div class="date-stamp"><span class="m">MAY</span><span class="d">22</span></div>
          <span class="card-tag hybrid">Hybrid</span>
        </div>
        <div class="card-body">
          <span class="card-group">Workshop · 90 min</span>
          <div class="card-title">Ash Framework workshop</div>
          <div class="card-meta">
            <span>Thu · 6:00 PM</span><span class="dot"></span><span>28 / 40 RSVPs</span>
          </div>
        </div>
      </a>
      <a class="card" href="/dev/design/clickthrough/huddl">
        <div class="card-cover gradient-4">
          <img class="card-cover-img" src="/dev/design/images/ai-meetup.svg" alt="" />
          <div class="date-stamp"><span class="m">MAY</span><span class="d">28</span></div>
          <span class="card-tag hybrid">Hybrid</span>
        </div>
        <div class="card-body">
          <span class="card-group">Talk · 60 min</span>
          <div class="card-title">LiveView deep dive</div>
          <div class="card-meta">
            <span>Wed · 6:30 PM</span><span class="dot"></span><span>34 / 60 RSVPs</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</.clickthrough_shell>
