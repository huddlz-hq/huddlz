<.clickthrough_shell active={@active} query={@query} signed_in={@signed_in}>
  <div class="page-head">
    <div>
      <h1>My groups</h1>
      <p>Groups you organize and groups you belong to.</p>
    </div>
  </div>

  <div class="filters">
    <button class="chip is-active">All · 5</button>
    <button class="chip">Hosting · 2</button>
    <button class="chip">Joined · 3</button>
  </div>

  <div class="grid">
    <a class="card" href="/dev/design/clickthrough/group">
      <div class="card-cover gradient-1">
        <img class="card-cover-img" src="/dev/design/images/product-night.svg" alt="" />
        <span class="card-tag hybrid">Hosting</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix · Programming</span>
        <div class="card-title">Phoenix Elixir</div>
        <div class="card-meta">
          <span>642 members</span><span class="dot"></span><span>5 upcoming</span>
        </div>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/group">
      <div class="card-cover gradient-2">
        <img class="card-cover-img" src="/dev/design/images/ai-meetup.svg" alt="" />
        <span class="card-tag hybrid">Hosting</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix · AI &amp; ML</span>
        <div class="card-title">Sonoran AI Collective</div>
        <div class="card-meta">
          <span>1,284 members</span><span class="dot"></span><span>3 upcoming</span>
        </div>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/group">
      <div class="card-cover gradient-3">
        <img class="card-cover-img" src="/dev/design/images/founder-coffee.svg" alt="" />
        <span class="card-tag in-person">Joined</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix · Outdoors</span>
        <div class="card-title">Trail Coffee Crew</div>
        <div class="card-meta">
          <span>89 members</span><span class="dot"></span><span>2 upcoming</span>
        </div>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/group">
      <div class="card-cover gradient-4">
        <img class="card-cover-img" src="/dev/design/images/ai-meetup.svg" alt="" />
        <span class="card-tag online">Joined</span>
      </div>
      <div class="card-body">
        <span class="card-group">Online · Books</span>
        <div class="card-title">Async Book Club</div>
        <div class="card-meta">
          <span>312 members</span><span class="dot"></span><span>1 upcoming</span>
        </div>
      </div>
    </a>
    <a class="card" href="/dev/design/clickthrough/group">
      <div class="card-cover gradient-5">
        <img class="card-cover-img" src="/dev/design/images/boat-drinks.svg" alt="" />
        <span class="card-tag in-person">Joined</span>
      </div>
      <div class="card-body">
        <span class="card-group">Phoenix · Music</span>
        <div class="card-title">Desert Synthesizer Society</div>
        <div class="card-meta">
          <span>156 members</span><span class="dot"></span><span>0 upcoming</span>
        </div>
      </div>
    </a>
  </div>
</.clickthrough_shell>
