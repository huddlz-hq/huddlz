<.clickthrough_shell active={@active} query={@query} signed_in={@signed_in}>
  <div class="auth-shell">
    <header class="auth-topbar">
      <a href="/dev/design/clickthrough/landing">
        <div class="brand-glyph">h</div>
        <div class="brand-text">huddlz</div>
      </a>
    </header>

    <div data-tw-container="Reset password — token state" class="auth-frame">
      <div data-tw-variant="Valid token">
        <h1>Set a new password</h1>
        <p class="lede">Almost there. Pick a new password and you'll be signed in.</p>

        <form class="auth-card" style="margin-top:18px">
          <div class="form-grid">
            <div class="form-row">
              <label class="form-label" for="rc-password">New password</label>
              <input
                id="rc-password"
                class="form-input"
                type="password"
                name="password"
                autocomplete="new-password"
              />
              <div class="form-help">At least 8 characters.</div>
            </div>
            <div class="form-row">
              <label class="form-label" for="rc-confirm">Confirm new password</label>
              <input
                id="rc-confirm"
                class="form-input"
                type="password"
                name="password_confirmation"
                autocomplete="new-password"
              />
            </div>
          </div>
          <div class="form-foot">
            <button type="submit" class="btn-primary">Reset password</button>
          </div>
        </form>
      </div>

      <div data-tw-variant="Expired token" hidden>
        <h1>Reset link expired</h1>
        <div class="auth-state warn" style="margin-top:12px">
          <div class="icon-mark">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="9" /><path d="M12 7v6" /><path d="M12 17h.01" />
            </svg>
          </div>
          <h2>This link is no longer valid</h2>
          <p>
            Reset links expire after a short window for security. Request a new one and we'll send a fresh link.
          </p>
          <a class="btn-primary" href="/dev/design/clickthrough/reset-request">
            Request a new link
          </a>
        </div>
      </div>
    </div>
  </div>
</.clickthrough_shell>
